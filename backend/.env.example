# Port the backend runs on locally
PORT=5001

# Local or Atlas MongoDB Connection URI
MONGO_URI=mongodb://localhost:27017/restaurant_reservations

# JWT Security Configuration
JWT_SECRET=replace_this_with_a_long_random_string
JWT_EXPIRES_IN=7d

# Local development frontend origin (CORS).
# In production (unified Vercel deployment), requests are same-origin and CORS is bypassed.
CLIENT_ORIGIN=http://localhost:5173
